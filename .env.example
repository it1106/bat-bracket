# PostHog Cloud project API key (browser-shipped). Leave unset to disable analytics.
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingestion host. Defaults to /ingest (same-origin reverse proxy
# defined in next.config.js) so ad-blockers don't drop events. Only set this
# to an absolute URL if you have a deployment that can't run Next rewrites.
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Deployment tagging for PostHog uses NEXT_PUBLIC_VERCEL_ENV, which Vercel
# injects automatically at build time. Don't set this manually — its presence
# is the signal that the build came from Vercel; absence means self-hosted.
